GEMINI_API_KEY=gemini-api-key

# Optional: pin the app to an existing Gemini File Search store.
# If blank, `python scraper/main.py` creates one on first run and stores it in SQLite.
GEMINI_FILE_SEARCH_STORE=

# Optional: environment-specific runtime overrides.
GEMINI_MODEL=gemini-3.1-flash-lite-preview
STATE_DB_PATH=data/state.db
RUN_ARTIFACT=last_run.json
OUT_DIR=data/markdown

# Optional: local frontend dev proxy target for `cd frontend && npm run dev`.
# The deployed app builds the frontend and lets the backend serve `frontend/dist`.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Optional: daily scraper cron schedule inside the scraper container.
SCRAPER_CRON_SCHEDULE=0 3 * * *
